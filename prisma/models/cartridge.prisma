model Cartridge {
  id            String         @id @default(cuid())
  name          String         @unique
  currentPrice  Decimal        @db.Decimal(10, 2)
  stock         Int            @default(0)
  imageUrl      String?
  printerModels PrinterModel[]
  stockEntries  StockEntry[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}